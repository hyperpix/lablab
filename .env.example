# Featherless.ai API Key — get yours at https://featherless.ai
VITE_FEATHERLESS_API_KEY=your_featherless_api_key_here

# Band.ai API Key & Agent UUIDs (optional, for telemetry)
VITE_BAND_API_KEY=your_band_api_key_here
VITE_SCRIBE_UUID=your_scribe_agent_uuid
VITE_PLANNER_UUID=your_planner_agent_uuid
VITE_PHARMACOLOGIST_UUID=your_pharmacologist_agent_uuid

# Neon DB (PostgreSQL) Configuration
VITE_DATABASE_URL=postgresql://user:password@host.tld/neondb?sslmode=require
